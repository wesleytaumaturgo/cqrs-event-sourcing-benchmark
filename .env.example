# PostgreSQL
POSTGRES_DB=cqrs_benchmark
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Datasource (Spring Boot)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cqrs_benchmark
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme

# Application
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=default

# Benchmark (JMH)
BENCHMARK_WARMUP_ITERATIONS=3
BENCHMARK_MEASUREMENT_ITERATIONS=5
BENCHMARK_FORKS=1
BENCHMARK_RECORDS=100000
POSTGRES_PORT=5433
